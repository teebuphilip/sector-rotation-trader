{
  "adapters": [
    "reddit_activity"
  ],
  "sliced_spec": {
    "id": "reddit-subreddit-mention-spike",
    "name": "Reddit Subreddit Mention Spike",
    "frequency": "daily",
    "universe": [
      "TSLA",
      "AAPL",
      "GME",
      "AMC",
      "NVDA",
      "MSFT",
      "AMD"
    ],
    "entry_exit": {
      "entry": "When mention count spike condition is met and price > 20-day SMA",
      "exit": "When mention counts revert below the 14-day moving average or price falls below the 20-day SMA"
    },
    "signal_logic": {
      "trigger": {
        "mention_spike": {
          "description": "Today's mention count exceeds 14-day moving average by at least 150%",
          "metric": "daily mention count",
          "baseline": "14-day moving average",
          "threshold": 1.5
        },
        "price_confirmation": {
          "description": "Price is above its 20-day simple moving average",
          "metric": "price",
          "baseline": "20-day SMA",
          "condition": "price > 20-day SMA"
        }
      }
    },
    "position_sizing": {
      "allocation_per_position": "5% of portfolio"
    },
    "data_sources": {
      "reddit": {}
    },
    "adapter_contracts": {
      "reddit_activity": {
        "func": "fetch_reddit_activity",
        "allowed_kwargs": [
          "subreddits",
          "days_back",
          "cache_key"
        ],
        "returns": [
          "date",
          "posts",
          "comments"
        ]
      }
    }
  }
}